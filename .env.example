# Resume Shortlisting Engine — environment template.
# Copy this file to ".env" and fill in the values you have.
#
# ALL VALUES ARE OPTIONAL. With no keys set, the engine runs fully offline on
# the rules tier and simply caps confidence at Medium. Adding keys unlocks the
# LLM cascade (Groq primary -> Gemini backup -> local Ollama) and High confidence.

# Primary cloud tier — Groq (llama-3.3-70b-versatile). Leave blank to skip.
GROQ_API_KEY=

# Backup cloud tier — Google Gemini Flash. Used only if Groq is unavailable.
GEMINI_API_KEY=

# Local offline fallback tier — Ollama host. Defaults to localhost.
# Requires: ollama pull qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Path to the Tesseract OCR binary (scanned/image resumes). Only needed when
# tesseract is not on PATH (typical on Windows). Leave blank on Linux/Mac if
# tesseract is already on PATH.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
